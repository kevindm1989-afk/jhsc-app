{
  "name": "@jhsc/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Worker-side JHSC app — SvelteKit web application.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --config vitest.bench.config.ts --run",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p ./tsconfig.json",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "9.16.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.65.2",
    "@sveltejs/vite-plugin-svelte": "4.0.0",
    "@testing-library/svelte": "5.3.1",
    "@types/node": "22.10.1",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "axe-core": "^4.12.1",
    "eslint": "9.16.0",
    "eslint-plugin-svelte": "2.46.1",
    "globals": "15.13.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "3.3.2",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "svelte-eslint-parser": "0.43.0",
    "typescript": "5.7.2",
    "vite": "5.4.21",
    "vitest": "3.2.6"
  },
  "dependencies": {
    "@sentry/sveltekit": "10.58.0",
    "libsodium-wrappers-sumo": "0.7.15"
  }
}
