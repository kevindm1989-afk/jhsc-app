# Environment variables — SHAPE only, never real secrets.
#
# Copy to `.env` for local dev; CI/Prod values are injected at deploy time.
# Per .context/constraints.md "Secrets handling": .env is gitignored.
#
# All required env vars are listed here so a new developer can boot the
# stack on a clean machine.

# --- Application ---
NODE_ENV=development                # development | test | ci | production
PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info                      # debug | info | warn | error | fatal

# --- Supabase (ADR-0001 — Canadian region) ---
# The local stack uses the `supabase start` defaults; production points at
# the ca-central-1 Supabase project. Region is verified at test setup by
# apps/web/test/_helpers/supabase-test.ts.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<your-local-anon-key>
# Edge-function-only secrets (NEVER ship to the browser bundle):
# HMAC_PSEUDONYM_KEY=<32-byte-base64>  # logger pseudonym key; Edge-function-side only
# SUPABASE_SERVICE_ROLE_KEY=<...>      # server-only; never in the browser

# --- Sentry (ADR-0010 — SaaS, EU/CA-eligible plan, SDK-layer scrubbing) ---
# The SDK is BUNDLED (no CDN); the DSN is consumed at boot. Browser builds
# read PUBLIC_SENTRY_DSN; Edge Functions / server read SENTRY_DSN.
# PUBLIC_SENTRY_DSN=<browser DSN; populated by deployer>
# SENTRY_DSN=<server/edge DSN; populated by deployer>
# SENTRY_RELEASE=<short git SHA; set at build time>
# SENTRY_ENVIRONMENT=<dev|staging|prod>

# --- Backup (ADR-0012 amendment — Backblaze B2 Canadian region) ---
# B2_KEY_ID=<scoped to {PutObject, GetObject, ListObjects}; never the master key>
# B2_APPLICATION_KEY=<...>
# B2_BUCKET_NAME=jhsc-backups-canada

# --- Feature flags (ADR — in-process, NO third-party SaaS) ---
# No env vars; flags live in src/lib/feature-flags.ts (compile-time defaults)
# and optionally the `feature_flags` Postgres table once T-feature-flag lands.

# --- Privacy / compliance ---
PRIVACY_CONTACT_EMAIL=privacy@example.ca
DATA_RETENTION_DAYS=2555            # 7y default per ADR-0015; per-event overrides in DB

# --- Development only ---
# DEBUG=app:*
# DISABLE_AUTH=false                # NEVER set to true in production

# ---------------------------------------------------------------------------
# HUMAN FOLLOW-UP REQUIRED BEFORE PRODUCTION DEPLOY
# ---------------------------------------------------------------------------
#  1. PUBLIC_SENTRY_DSN + SENTRY_DSN — provisioning held by the deployer.
#  2. HMAC_PSEUDONYM_KEY — generated by `openssl rand -base64 32`, stored
#     in the deployer's secret manager; NEVER in the browser bundle (the
#     scripts/verify-no-third-party-js.sh gate enforces).
#  3. B2_KEY_ID + B2_APPLICATION_KEY — provisioning per ADR-0012 amendment;
#     scope MUST be {PutObject, GetObject, ListObjects} only.
#  4. Supabase project ID + ca-central-1 region selection (ADR-0001) —
#     created in the dashboard, not config.toml.
# ---------------------------------------------------------------------------
