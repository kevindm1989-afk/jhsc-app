# Agent OS self-protection.
# The feedback log accumulates raw outcomes that may contain real ticket
# excerpts, names, or incident specifics. It stays local; only the
# curated, sanitized output (in lessons.md / patterns.md / decisions.md)
# gets committed. See .gitignore.template for the same rule that ships
# to projects adopting this pack.
.context/feedback-log.md

# --- Node / pnpm ---
node_modules/
.pnpm-store/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Env / secrets ---
.env
.env.local
.env.*.local

# --- Builds / caches ---
.svelte-kit/
build/
dist/
coverage/
.vite/
.vitest/
.turbo/

# --- IDE ---
.idea/
.vscode/
*.swp

# --- OS ---
.DS_Store
Thumbs.db

# --- Test artifacts ---
playwright-report/
test-results/
.nyc_output/

# --- Supabase local ---
supabase/.temp/
supabase/.branches/
# Locally-generated ES256 signing keys for the mint live-stack e2e
# (scripts/mint-live-e2e.sh). Contains PRIVATE key material — never commit.
supabase/signing_keys.local.json

